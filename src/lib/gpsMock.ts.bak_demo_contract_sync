type Vehicle = {
  id: string;
  contract_id: string;
  plate: string;
  lat: number;
  lng: number;
  status?: string;
};

const makeFleet = (n: number): Vehicle[] =>
  Array.from({ length: n }).map((_, i) => {
    const baseLat = 11.55 + Math.random() * 0.05;
    const baseLng = 104.92 + Math.random() * 0.05;

    return {
      id: String(i + 1),
      contract_id: `C-${i + 1}`,
      plate: `A-${1000 + i}`,
      lat: baseLat,
      lng: baseLng,
      status: 
      Math.random() > 0.95
        ? "IMMOBILIZER_ARMED"
        : Math.random() > 0.85
        ? "COLLECTION_RISK"
        : "ACTIVE"
    ,
    };
  });

let state: Vehicle[] = makeFleet(57);

export function subscribeGPS(cb: (v: Vehicle[]) => void) {
  cb(state);

  setInterval(() => {
const hash = (str: string) => {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = (h * 31 + str.charCodeAt(i)) >>> 0;
  }
  return h;
};

const getStatus = (contractId: string) => {
  const h = hash(contractId);

  if (h % 100 < 5) return "IMMOBILIZER_ARMED";
  if (h % 100 < 15) return "COLLECTION_RISK";
  return "ACTIVE";
};
    state = state.map(v => ({
      ...v,
  status: getStatus(v.contract_id),  
  lat: v.lat + (Math.random() - 0.5) * 0.002,
  lng: v.lng + (Math.random() - 0.5) * 0.002,
   }));

    cb(state);
  }, 1000);
}

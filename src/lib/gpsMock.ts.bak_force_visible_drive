import { api } from "../services/api";

export type Vehicle = {
  id: string;
  contract_id: string;
  client?: string;
  plate: string;
  lat: number;
  lng: number;
  speed?: number;
  status: "ONLINE" | "OVERDUE_WATCH" | "COLLECTION_RISK" | "IMMOBILIZER_ARMED";
};

const CENTER = { lat: 11.5564, lng: 104.9282 };

let vehicles: Vehicle[] = [];
let loaded = false;

const motion = new Map<string, { heading: number }>();

function hash(seed: string) {
  let h = 0;
  for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) >>> 0;
  return h;
}

function offset(seed: string, scale: number) {
  return ((hash(seed) % 2000) / 1000 - 1) * scale;
}

function statusFrom(contract: any, kase: any): Vehicle["status"] {
  if (kase?.status === "IMMOBILIZED") return "IMMOBILIZER_ARMED";
  if (kase?.status === "APPROVED") return "COLLECTION_RISK";
  if (kase?.status === "OPEN") return "COLLECTION_RISK";
  if (contract?.status === "IMMOBILIZER_ARMED") return "IMMOBILIZER_ARMED";
  if (contract?.status === "OVERDUE" || contract?.status === "DELINQUENT") return "COLLECTION_RISK";
  return "ONLINE";
}

async function syncFromApi() {
  const data = await api.getGps();

  const contracts = data.contracts || [];
  const cases = data.cases || [];
  const gpsVehicles = data.vehicles || [];

  const previous = new Map(vehicles.map((v) => [String(v.contract_id), v]));

  vehicles = contracts.map((contract: any, index: number) => {
    const contractId = String(contract.id || contract.contract_id);
    const old = previous.get(contractId);
    const existingGps: any = gpsVehicles.find((v: any) => String(v.contract_id) === contractId);
    const kase = cases.find((c: any) => String(c.contract_id) === contractId);

    const id = String(
      old?.id ||
      existingGps?.id ||
      contract.vehicle_id ||
      contract.vehicleId ||
      `vehicle-${contractId}`
    );

    const status = statusFrom(contract, kase);

    return {
      id,
      contract_id: contractId,
      client: contract.client || contract.client_name || contract.customer_name || old?.client || "-",
      plate: String(existingGps?.plate || contract.plate || contract.vehicle_plate || old?.plate || `DEMO-${index + 1}`),
      lat: old?.lat ?? existingGps?.lat ?? CENTER.lat + offset(contractId, 0.035),
      lng: old?.lng ?? existingGps?.lng ?? CENTER.lng + offset(contractId + "-lng", 0.035),
      speed: status === "IMMOBILIZER_ARMED" ? 0 : status === "COLLECTION_RISK" ? 12 : 25,
      status,
    };
  });

  loaded = true;
}

function moveOnce() {
  vehicles = vehicles.map((v, index) => {
    if (v.status === "IMMOBILIZER_ARMED") {
      return { ...v, speed: 0 };
    }

    let m = motion.get(v.id);
    if (!m) {
      m = { heading: ((index * 41 + hash(v.id) % 90) % 360) * Math.PI / 180 };
      motion.set(v.id, m);
    }

    const speed = v.status === "COLLECTION_RISK" ? 12 : 25;

    // Large enough to be visible in demo, smooth enough not to shake.
    const step = v.status === "COLLECTION_RISK" ? 0.00018 : 0.00028;

    const lat = v.lat + Math.cos(m.heading) * step;
    const lng = v.lng + Math.sin(m.heading) * step;

    m.heading += 0.015;

    return {
      ...v,
      lat,
      lng,
      speed,
    };
  });
}

export function subscribeGPS(cb: (v: Vehicle[]) => void) {
  let cancelled = false;

  async function initialLoad() {
    try {
      await syncFromApi();
      if (!cancelled) cb([...vehicles]);
    } catch (e) {
      console.error("GPS initial sync failed", e);
    }
  }

  initialLoad();

  const moveTimer = window.setInterval(() => {
    if (!loaded || cancelled) return;
    moveOnce();
    cb([...vehicles]);
  }, 1000);

  const syncTimer = window.setInterval(async () => {
    if (cancelled) return;
    try {
      await syncFromApi();
      if (!cancelled) cb([...vehicles]);
    } catch (e) {
      console.error("GPS API sync failed", e);
    }
  }, 8000);

  return () => {
    cancelled = true;
    window.clearInterval(moveTimer);
    window.clearInterval(syncTimer);
  };
}
